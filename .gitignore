# Keep LaTeX source files and bibliography files
!*.tex
!*.cls
!*.sty
!*.bib
!*.bst

# Generated validation / temporary reports
tmp/
temp/
.cache/
.cache-*/
reports/generated/
validation-output/
*.validated.json

# Upstream tracking runtime files
# Keep source manifests, baseline snapshots, and curated reports.
# Ignore transient API responses and scratch outputs.
.upstream/cache/
.upstream/tmp/
.upstream/raw/
.upstream/**/*.tmp
.upstream/**/*.bak

# Keep intended upstream files
!.upstream/
!.upstream/README.md
!.upstream/sources.json
!.upstream/sources.yaml
!.upstream/snapshots/
!.upstream/snapshots/latest.json
!.upstream/reports/
!.upstream/reports/upstream-report.md
!.upstream/reports/upstream-state.json

# Agent runtime scratch files
.agents/tmp/
.agents/cache/
.agents/logs/
.agents/**/*.tmp
.agents/**/*.bak

# Keep skill definitions
!.agents/
!.agents/skills/
!.agents/skills/**

# Logs
*.log
logs/

# Coverage / benchmark scratch outputs
coverage/
bench-output/
benchmark-output/

# Local packaged copies of this project
academic_writing_skill_suite*.zip
academic-writing-skills*.zip

# Optional local vendor checkouts
# If you later clone upstream repositories locally, keep them out of git.
vendor/
.external/
third_party/

# GitHub Actions local runner state
_act/